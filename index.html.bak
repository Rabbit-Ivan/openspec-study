<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpenSpec 工作流指南 | 新 → 续 → 用 → 档</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --ink-black: #0a0a0b;
      --ink-dark: #1a1a1d;
      --ink-medium: #2d2d32;
      --ink-light: #3d3d44;
      --paper: #f5f3ef;
      --paper-warm: #ebe7df;
      --vermilion: #e74c3c;
      --vermilion-glow: #ff6b5b;
      --jade: #2ecc71;
      --jade-glow: #4ade80;
      --gold: #f39c12;
      --gold-glow: #fbbf24;
      --ink-wash: rgba(10, 10, 11, 0.7);
      --text-primary: #e8e6e3;
      --text-secondary: #9ca3af;
      --text-muted: #6b7280;
      --terminal-green: #4ade80;
      --terminal-cursor: #fbbf24;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Noto Serif SC', serif;
      background: var(--ink-black);
      color: var(--text-primary);
      line-height: 1.8;
      overflow-x: hidden;
    }

    /* Ink wash background texture */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background:
        radial-gradient(ellipse at 20% 20%, rgba(45, 45, 50, 0.4) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 80%, rgba(45, 45, 50, 0.3) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(30, 30, 35, 0.2) 0%, transparent 70%);
      pointer-events: none;
      z-index: -1;
    }

    /* Noise texture overlay */
    body::after {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      opacity: 0.03;
      pointer-events: none;
      z-index: -1;
    }

    .code-font {
      font-family: 'JetBrains Mono', monospace;
    }

    /* Header */
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: linear-gradient(to bottom, var(--ink-black) 0%, transparent 100%);
    }

    .logo {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .logo-icon {
      width: 32px;
      height: 32px;
      background: linear-gradient(135deg, var(--jade) 0%, var(--jade-glow) 100%);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    .nav {
      display: flex;
      gap: 2rem;
    }

    .nav a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.3s ease;
    }

    .nav a:hover {
      color: var(--text-primary);
    }

    /* Hero Section */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 6rem 2rem;
      text-align: center;
      position: relative;
    }

    .hero-badge {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: var(--jade);
      background: rgba(46, 204, 113, 0.1);
      border: 1px solid rgba(46, 204, 113, 0.3);
      padding: 0.5rem 1rem;
      border-radius: 100px;
      margin-bottom: 2rem;
      animation: fadeInUp 0.8s ease-out;
    }

    .hero-title {
      font-size: clamp(3rem, 8vw, 6rem);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      animation: fadeInUp 0.8s ease-out 0.1s both;
    }

    .hero-title .accent {
      background: linear-gradient(135deg, var(--jade) 0%, var(--jade-glow) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subtitle {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin-bottom: 3rem;
      animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .hero-mantra {
      font-family: 'JetBrains Mono', monospace;
      font-size: 2rem;
      color: var(--text-primary);
      margin-bottom: 3rem;
      animation: fadeInUp 0.8s ease-out 0.3s both;
    }

    .hero-mantra span {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      margin: 0 0.25rem;
      border-radius: 4px;
      transition: all 0.3s ease;
    }

    .hero-mantra span:nth-child(1) { background: rgba(46, 204, 113, 0.2); color: var(--jade-glow); }
    .hero-mantra span:nth-child(2) { background: rgba(243, 156, 18, 0.2); color: var(--gold-glow); }
    .hero-mantra span:nth-child(3) { background: rgba(231, 76, 60, 0.2); color: var(--vermilion-glow); }
    .hero-mantra span:nth-child(4) { background: rgba(74, 222, 128, 0.2); color: var(--jade-glow); }

    .hero-mantra span:hover {
      transform: translateY(-4px);
    }

    .scroll-hint {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-muted);
      font-size: 0.8rem;
      animation: bounce 2s infinite;
    }

    .scroll-hint::after {
      content: '↓';
      font-size: 1.5rem;
    }

    /* Section Styles */
    section {
      padding: 6rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: var(--jade);
      text-transform: uppercase;
      letter-spacing: 0.2em;
      margin-bottom: 1rem;
    }

    .section-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .section-desc {
      color: var(--text-secondary);
      font-size: 1.1rem;
      max-width: 700px;
      margin-bottom: 3rem;
    }

    /* Command Cards */
    .command-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .command-card {
      background: var(--ink-dark);
      border: 1px solid var(--ink-medium);
      border-radius: 12px;
      padding: 2rem;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .command-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--jade), var(--jade-glow));
      transform: scaleX(0);
      transition: transform 0.3s ease;
    }

    .command-card:hover::before {
      transform: scaleX(1);
    }

    .command-card:hover {
      border-color: var(--ink-light);
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .command-card.essential {
      border-color: var(--jade);
      background: linear-gradient(135deg, rgba(46, 204, 113, 0.05) 0%, transparent 100%);
    }

    .command-card.essential::before {
      transform: scaleX(1);
    }

    .command-type {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.75rem;
    }

    .command-name {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.1rem;
      color: var(--jade-glow);
      margin-bottom: 0.5rem;
    }

    .command-chinese {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }

    .command-desc {
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    /* Workflow Section */
    .workflow-container {
      background: var(--ink-dark);
      border: 1px solid var(--ink-medium);
      border-radius: 16px;
      overflow: hidden;
      margin-top: 2rem;
    }

    .workflow-tabs {
      display: flex;
      border-bottom: 1px solid var(--ink-medium);
    }

    .workflow-tab {
      flex: 1;
      padding: 1.25rem 1.5rem;
      background: transparent;
      border: none;
      color: var(--text-secondary);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
    }

    .workflow-tab::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--jade);
      transform: scaleX(0);
      transition: transform 0.3s ease;
    }

    .workflow-tab:hover {
      color: var(--text-primary);
      background: rgba(255, 255, 255, 0.02);
    }

    .workflow-tab.active {
      color: var(--jade-glow);
    }

    .workflow-tab.active::after {
      transform: scaleX(1);
    }

    .workflow-content {
      padding: 2rem;
    }

    .workflow-panel {
      display: none;
    }

    .workflow-panel.active {
      display: block;
      animation: fadeIn 0.4s ease;
    }

    /* Terminal Style */
    .terminal {
      background: var(--ink-black);
      border: 1px solid var(--ink-medium);
      border-radius: 8px;
      overflow: hidden;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem;
    }

    .terminal-header {
      background: var(--ink-medium);
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .terminal-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }

    .terminal-dot.red { background: #ff5f56; }
    .terminal-dot.yellow { background: #ffbd2e; }
    .terminal-dot.green { background: #27ca40; }

    .terminal-body {
      padding: 1.5rem;
      line-height: 1.8;
      max-height: 400px;
      overflow-y: auto;
    }

    .terminal-line {
      margin-bottom: 0.5rem;
      opacity: 0;
      animation: terminalType 0.3s ease forwards;
    }

    .terminal-line:nth-child(1) { animation-delay: 0.1s; }
    .terminal-line:nth-child(2) { animation-delay: 0.3s; }
    .terminal-line:nth-child(3) { animation-delay: 0.5s; }
    .terminal-line:nth-child(4) { animation-delay: 0.7s; }
    .terminal-line:nth-child(5) { animation-delay: 0.9s; }
    .terminal-line:nth-child(6) { animation-delay: 1.1s; }
    .terminal-line:nth-child(7) { animation-delay: 1.3s; }
    .terminal-line:nth-child(8) { animation-delay: 1.5s; }
    .terminal-line:nth-child(9) { animation-delay: 1.7s; }
    .terminal-line:nth-child(10) { animation-delay: 1.9s; }
    .terminal-line:nth-child(11) { animation-delay: 2.1s; }
    .terminal-line:nth-child(12) { animation-delay: 2.3s; }
    .terminal-line:nth-child(13) { animation-delay: 2.5s; }
    .terminal-line:nth-child(14) { animation-delay: 2.7s; }
    .terminal-line:nth-child(15) { animation-delay: 2.9s; }
    .terminal-line:nth-child(16) { animation-delay: 3.1s; }
    .terminal-line:nth-child(17) { animation-delay: 3.3s; }
    .terminal-line:nth-child(18) { animation-delay: 3.5s; }

    .terminal-prompt {
      color: var(--jade-glow);
    }

    .terminal-command {
      color: var(--gold-glow);
    }

    .terminal-output {
      color: var(--text-secondary);
    }

    .terminal-success {
      color: var(--jade-glow);
    }

    .terminal-comment {
      color: var(--text-muted);
      font-style: italic;
    }

    /* Flow Diagram */
    .flow-diagram {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      padding: 3rem 1rem;
      flex-wrap: wrap;
    }

    .flow-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .flow-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .flow-icon:hover {
      transform: scale(1.1);
    }

    .flow-step:nth-child(1) .flow-icon {
      background: linear-gradient(135deg, rgba(46, 204, 113, 0.2), rgba(46, 204, 113, 0.1));
      border: 2px solid var(--jade);
    }
    .flow-step:nth-child(3) .flow-icon {
      background: linear-gradient(135deg, rgba(243, 156, 18, 0.2), rgba(243, 156, 18, 0.1));
      border: 2px solid var(--gold);
    }
    .flow-step:nth-child(5) .flow-icon {
      background: linear-gradient(135deg, rgba(231, 76, 60, 0.2), rgba(231, 76, 60, 0.1));
      border: 2px solid var(--vermilion);
    }
    .flow-step:nth-child(7) .flow-icon {
      background: linear-gradient(135deg, rgba(74, 222, 128, 0.2), rgba(74, 222, 128, 0.1));
      border: 2px solid var(--jade-glow);
    }

    .flow-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .flow-chinese {
      font-size: 1.25rem;
      font-weight: 600;
    }

    .flow-arrow {
      font-size: 1.5rem;
      color: var(--text-muted);
    }

    /* Scenario Section */
    .scenario-box {
      background: linear-gradient(135deg, var(--ink-dark) 0%, var(--ink-medium) 100%);
      border: 1px solid var(--ink-light);
      border-radius: 16px;
      padding: 2.5rem;
      margin-bottom: 2rem;
    }

    .scenario-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .scenario-icon {
      font-size: 2.5rem;
    }

    .scenario-title {
      font-size: 1.5rem;
      font-weight: 600;
    }

    .scenario-subtitle {
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    .step-list {
      list-style: none;
      counter-reset: step;
    }

    .step-item {
      counter-increment: step;
      padding: 1.5rem;
      background: var(--ink-black);
      border: 1px solid var(--ink-medium);
      border-radius: 8px;
      margin-bottom: 1rem;
      position: relative;
      padding-left: 4rem;
    }

    .step-item::before {
      content: counter(step);
      position: absolute;
      left: 1.5rem;
      top: 1.5rem;
      width: 28px;
      height: 28px;
      background: var(--jade);
      color: var(--ink-black);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 600;
      font-size: 0.8rem;
    }

    .step-command {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem;
      color: var(--gold-glow);
      background: rgba(243, 156, 18, 0.1);
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      margin-bottom: 0.5rem;
      display: inline-block;
    }

    .step-desc {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    .step-result {
      margin-top: 1rem;
      padding: 1rem;
      background: rgba(46, 204, 113, 0.05);
      border-left: 3px solid var(--jade);
      border-radius: 0 4px 4px 0;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    /* Quick Reference */
    .quick-ref {
      background: var(--ink-dark);
      border: 2px solid var(--jade);
      border-radius: 16px;
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
    }

    .quick-ref::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(135deg, rgba(46, 204, 113, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }

    .quick-ref-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .quick-ref-subtitle {
      color: var(--text-secondary);
      margin-bottom: 2rem;
    }

    .ref-table {
      width: 100%;
      border-collapse: collapse;
    }

    .ref-table th,
    .ref-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--ink-medium);
    }

    .ref-table th {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .ref-table td:first-child {
      font-family: 'JetBrains Mono', monospace;
      color: var(--gold-glow);
    }

    .ref-table td:nth-child(2) {
      font-weight: 600;
    }

    .ref-table tr:hover {
      background: rgba(255, 255, 255, 0.02);
    }

    /* Footer */
    .footer {
      padding: 4rem 2rem;
      text-align: center;
      border-top: 1px solid var(--ink-medium);
      margin-top: 4rem;
    }

    .footer-mantra {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }

    .footer-mantra span {
      display: inline-block;
      padding: 0.25rem 0.5rem;
      margin: 0 0.25rem;
      border-radius: 4px;
    }

    .footer-mantra span:nth-child(1) { color: var(--jade-glow); }
    .footer-mantra span:nth-child(2) { color: var(--gold-glow); }
    .footer-mantra span:nth-child(3) { color: var(--vermilion-glow); }
    .footer-mantra span:nth-child(4) { color: var(--jade-glow); }

    .footer-text {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes bounce {
      0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
      40% { transform: translateX(-50%) translateY(-10px); }
      60% { transform: translateX(-50%) translateY(-5px); }
    }

    @keyframes terminalType {
      from {
        opacity: 0;
        transform: translateX(-10px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }

    .cursor {
      display: inline-block;
      width: 10px;
      height: 1.2em;
      background: var(--terminal-cursor);
      margin-left: 2px;
      animation: blink 1s infinite;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .header {
        padding: 1rem 1.5rem;
      }

      .nav {
        display: none;
      }

      .hero-title {
        font-size: 2.5rem;
      }

      .hero-mantra {
        font-size: 1.25rem;
      }

      .hero-mantra span {
        display: block;
        margin: 0.5rem 0;
      }

      section {
        padding: 3rem 1rem;
      }

      .flow-diagram {
        flex-direction: column;
      }

      .flow-arrow {
        transform: rotate(90deg);
      }

      .workflow-tabs {
        flex-direction: column;
      }

      .step-item {
        padding-left: 3.5rem;
      }

      .step-item::before {
        left: 1rem;
      }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="logo">
      <div class="logo-icon">◇</div>
      OpenSpec
    </div>
    <nav class="nav">
      <a href="#commands">命令</a>
      <a href="#workflow">工作流</a>
      <a href="#scenario">实战演练</a>
      <a href="#reference">速查表</a>
      <a href="#tools">工具兼容</a>
    </nav>
  </header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-badge">OPSX · Artifact-Driven Workflow · 22+ Tools</div>
    <h1 class="hero-title">
      <span class="accent">OpenSpec</span><br>
      工作流指南
    </h1>
    <p class="hero-subtitle">
      从繁杂命令到四字口诀，掌握 AI 驱动的规格驱动开发工作流
    </p>
    <div class="hero-mantra">
      <span>新</span>
      <span>续</span>
      <span>用</span>
      <span>档</span>
    </div>
    <div class="scroll-hint">
      向下探索
    </div>
  </section>

  <!-- Commands Section -->
  <section id="commands">
    <div class="section-label">核心命令</div>
    <h2 class="section-title">命令分类一览</h2>
    <p class="section-desc">
      看似命令很多，实则分为三类：主线命令（必用）、速度控制（二选一）、辅助命令（按需）
    </p>

    <h3 style="color: var(--jade-glow); margin-bottom: 1rem; font-size: 1.1rem;">主线命令 · 必须掌握</h3>
    <div class="command-grid">
      <div class="command-card essential">
        <div class="command-type">创建</div>
        <div class="command-name">/opsx:new</div>
        <div class="command-chinese">新</div>
        <div class="command-desc">创建一个新的变更目录，开始规划你的功能</div>
      </div>
      <div class="command-card essential">
        <div class="command-type">实施</div>
        <div class="command-name">/opsx:apply</div>
        <div class="command-chinese">用</div>
        <div class="command-desc">执行 tasks.md 中的任务，开始写代码</div>
      </div>
      <div class="command-card essential">
        <div class="command-type">归档</div>
        <div class="command-name">/opsx:archive</div>
        <div class="command-chinese">档</div>
        <div class="command-desc">完成后归档，保存到 archive 目录</div>
      </div>
    </div>

    <h3 style="color: var(--gold-glow); margin: 2rem 0 1rem; font-size: 1.1rem;">速度控制 · 二选一</h3>
    <div class="command-grid">
      <div class="command-card">
        <div class="command-type">快进模式</div>
        <div class="command-name">/opsx:ff</div>
        <div class="command-chinese">快进</div>
        <div class="command-desc">一口气生成所有文档（proposal → specs → design → tasks），适合中小功能</div>
      </div>
      <div class="command-card">
        <div class="command-type">逐步模式</div>
        <div class="command-name">/opsx:continue</div>
        <div class="command-chinese">续</div>
        <div class="command-desc">每次只生成一个文档，可以逐步审核，适合重要功能</div>
      </div>
    </div>

    <h3 style="color: var(--text-secondary); margin: 2rem 0 1rem; font-size: 1.1rem;">辅助命令 · 按需使用</h3>
    <div class="command-grid">
      <div class="command-card">
        <div class="command-type">调研</div>
        <div class="command-name">/opsx:explore</div>
        <div class="command-chinese">探</div>
        <div class="command-desc">只思考不写文件，用于前期调研和方案比较</div>
      </div>
      <div class="command-card">
        <div class="command-type">验证</div>
        <div class="command-name">/opsx:verify</div>
        <div class="command-chinese">验</div>
        <div class="command-desc">三维度验证：完整性、正确性、一致性，确保实现符合规格</div>
      </div>
      <div class="command-card">
        <div class="command-type">同步</div>
        <div class="command-name">/opsx:sync</div>
        <div class="command-chinese">同</div>
        <div class="command-desc">把变更的 spec 合并到主 specs 目录（archive 时会自动提示）</div>
      </div>
      <div class="command-card">
        <div class="command-type">批量归档</div>
        <div class="command-name">/opsx:bulk-archive</div>
        <div class="command-chinese">批档</div>
        <div class="command-desc">一次归档多个已完成的变更，自动检测 spec 冲突并解决</div>
      </div>
      <div class="command-card">
        <div class="command-type">引导教程</div>
        <div class="command-name">/opsx:onboard</div>
        <div class="command-chinese">学</div>
        <div class="command-desc">交互式引导教程，用真实代码库走一遍完整工作流</div>
      </div>
    </div>
  </section>

  <!-- Workflow Section -->
  <section id="workflow">
    <div class="section-label">工作流程</div>
    <h2 class="section-title">两种模式对比</h2>
    <p class="section-desc">
      根据功能复杂度选择：快速模式适合日常开发，精细模式适合重要功能
    </p>

    <div class="flow-diagram">
      <div class="flow-step">
        <div class="flow-icon">🆕</div>
        <div class="flow-chinese">新</div>
        <div class="flow-label">new</div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-icon">📝</div>
        <div class="flow-chinese">续</div>
        <div class="flow-label">continue/ff</div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-icon">⚡</div>
        <div class="flow-chinese">用</div>
        <div class="flow-label">apply</div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-icon">📦</div>
        <div class="flow-chinese">档</div>
        <div class="flow-label">archive</div>
      </div>
    </div>

    <div class="workflow-container">
      <div class="workflow-tabs">
        <button class="workflow-tab active" onclick="showWorkflow('fast')">⚡ 快速模式</button>
        <button class="workflow-tab" onclick="showWorkflow('detailed')">🔍 精细模式</button>
        <button class="workflow-tab" onclick="showWorkflow('parallel')">🔀 并行模式</button>
      </div>
      <div class="workflow-content">
        <!-- Fast Mode -->
        <div class="workflow-panel active" id="workflow-fast">
          <div class="terminal">
            <div class="terminal-header">
              <div class="terminal-dot red"></div>
              <div class="terminal-dot yellow"></div>
              <div class="terminal-dot green"></div>
            </div>
            <div class="terminal-body">
              <div class="terminal-line"><span class="terminal-comment"># 第一步：创建 + 快进生成所有文档</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:ff</span></div>
              <div class="terminal-line"><span class="terminal-output">AI：你想做什么功能？</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-output">我想给产品添加收藏功能</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已生成 proposal.md, specs/, design.md, tasks.md</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 第二步：执行任务</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:apply</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 开始执行 tasks.md 中的任务...</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 第三步：归档</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:archive</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已归档到 archive/</span></div>
            </div>
          </div>
          <p style="margin-top: 1.5rem; color: var(--text-secondary); text-align: center;">
            总共 <strong style="color: var(--jade-glow);">3 个命令</strong>，和旧版体验一致
          </p>
        </div>

        <!-- Detailed Mode -->
        <div class="workflow-panel" id="workflow-detailed">
          <div class="terminal">
            <div class="terminal-header">
              <div class="terminal-dot red"></div>
              <div class="terminal-dot yellow"></div>
              <div class="terminal-dot green"></div>
            </div>
            <div class="terminal-body">
              <div class="terminal-line"><span class="terminal-comment"># 第一步：先调研（可选）</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:explore</span></div>
              <div class="terminal-line"><span class="terminal-output">帮我调研一下用户系统和数据库结构</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 第二步：创建变更</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:new "product-favorites"</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已创建变更目录</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 第三步：逐个生成文档（每次可审核）</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:continue</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已生成 proposal.md</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:continue</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已生成 specs/</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:continue</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已生成 design.md</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:continue</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已生成 tasks.md</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 第四步：执行 → 验证 → 归档</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:apply</span> → <span class="terminal-command">/opsx:verify</span> → <span class="terminal-command">/opsx:archive</span></div>
            </div>
          </div>
          <p style="margin-top: 1.5rem; color: var(--text-secondary); text-align: center;">
            每一步都可以 <strong style="color: var(--gold-glow);">审核和调整</strong>，适合重要功能
          </p>
        </div>

        <!-- Parallel Mode -->
        <div class="workflow-panel" id="workflow-parallel">
          <div class="terminal">
            <div class="terminal-header">
              <div class="terminal-dot red"></div>
              <div class="terminal-dot yellow"></div>
              <div class="terminal-dot green"></div>
            </div>
            <div class="terminal-body">
              <div class="terminal-line"><span class="terminal-comment"># 同时开多个变更，随时切换</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:ff</span><span class="terminal-output"> add-dark-mode</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已生成所有文档</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:apply</span></div>
              <div class="terminal-line"><span class="terminal-output">正在实现 dark-mode... 被紧急 bug 打断</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 切换到紧急修复</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:ff</span><span class="terminal-output"> fix-login-redirect</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:apply</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 修复完成</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:archive</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 回到 dark-mode 继续</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:apply</span><span class="terminal-output"> add-dark-mode</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 从上次中断处继续...</span></div>
              <div class="terminal-line"></div>
              <div class="terminal-line"><span class="terminal-comment"># 多个变更完成后，批量归档</span></div>
              <div class="terminal-line"><span class="terminal-prompt">你：</span><span class="terminal-command">/opsx:bulk-archive</span></div>
              <div class="terminal-line"><span class="terminal-success">✓ 已批量归档 3 个变更，自动解决 spec 冲突</span></div>
            </div>
          </div>
          <p style="margin-top: 1.5rem; color: var(--text-secondary); text-align: center;">
            支持 <strong style="color: var(--vermilion-glow);">并行开发</strong>，随时切换上下文，用 <strong style="color: var(--gold-glow);">bulk-archive</strong> 批量收尾
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Scenario Section -->
  <section id="scenario">
    <div class="section-label">实战演练</div>
    <h2 class="section-title">场景：给 Benzenith 添加产品收藏功能</h2>
    <p class="section-desc">
      让我们用一个真实场景，完整走一遍 OpenSpec 工作流
    </p>

    <div class="scenario-box">
      <div class="scenario-header">
        <div class="scenario-icon">💎</div>
        <div>
          <div class="scenario-title">产品收藏功能</div>
          <div class="scenario-subtitle">用户可以收藏喜欢的珠宝产品，在个人中心查看</div>
        </div>
      </div>

      <ol class="step-list">
        <li class="step-item">
          <div class="step-command">/opsx:ff</div>
          <div class="step-desc">告诉 AI 你想做什么功能</div>
          <div class="step-result">
            ✓ 自动创建变更目录<br>
            ✓ 生成 proposal.md（为什么做）<br>
            ✓ 生成 specs/favorites/spec.md（行为规格）<br>
            ✓ 生成 design.md（技术方案）<br>
            ✓ 生成 tasks.md（任务清单）
          </div>
        </li>
        <li class="step-item">
          <div class="step-command">/opsx:apply</div>
          <div class="step-desc">AI 按 tasks.md 逐项执行代码任务</div>
          <div class="step-result">
            [x] 1.1 创建 favorites 数据库表<br>
            [x] 1.2 添加 Drizzle schema<br>
            [x] 2.1 实现收藏 API<br>
            [x] 2.2 实现取消收藏 API<br>
            [x] 3.1 产品卡片添加收藏按钮<br>
            [x] 3.2 个人中心收藏列表页
          </div>
        </li>
        <li class="step-item">
          <div class="step-command">/opsx:archive</div>
          <div class="step-desc">功能完成，归档到 archive 目录</div>
          <div class="step-result">
            ✓ 已归档到 openspec/changes/archive/2025-02-01-product-favorites/
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Quick Reference -->
  <section id="reference">
    <div class="quick-ref">
      <h2 class="quick-ref-title">📋 速查表</h2>
      <p class="quick-ref-subtitle">打印出来贴在显眼处</p>

      <table class="ref-table">
        <thead>
          <tr>
            <th>命令</th>
            <th>中文</th>
            <th>作用</th>
            <th>使用场景</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>/opsx:ff</td>
            <td>快进</td>
            <td>创建 + 生成所有文档</td>
            <td>日常开发首选</td>
          </tr>
          <tr>
            <td>/opsx:new</td>
            <td>新</td>
            <td>只创建变更目录</td>
            <td>需要逐步审核时</td>
          </tr>
          <tr>
            <td>/opsx:continue</td>
            <td>续</td>
            <td>生成下一个文档</td>
            <td>配合 new 使用</td>
          </tr>
          <tr>
            <td>/opsx:apply</td>
            <td>用</td>
            <td>执行任务列表</td>
            <td>开始写代码</td>
          </tr>
          <tr>
            <td>/opsx:verify</td>
            <td>验</td>
            <td>三维度验证实现</td>
            <td>归档前检查（推荐）</td>
          </tr>
          <tr>
            <td>/opsx:archive</td>
            <td>档</td>
            <td>归档完成</td>
            <td>收尾必用</td>
          </tr>
          <tr>
            <td>/opsx:explore</td>
            <td>探</td>
            <td>只调研不写文件</td>
            <td>不确定要不要做时</td>
          </tr>
          <tr>
            <td>/opsx:sync</td>
            <td>同</td>
            <td>合并 delta specs</td>
            <td>archive 会自动提示</td>
          </tr>
          <tr>
            <td>/opsx:bulk-archive</td>
            <td>批档</td>
            <td>批量归档多个变更</td>
            <td>并行开发收尾</td>
          </tr>
          <tr>
            <td>/opsx:onboard</td>
            <td>学</td>
            <td>交互式引导教程</td>
            <td>新手入门首选</td>
          </tr>
        </tbody>
      </table>

      <div style="margin-top: 2rem; padding: 1.5rem; background: var(--ink-black); border-radius: 8px; text-align: center;">
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 1.25rem; margin-bottom: 0.5rem;">
          记忆口诀
        </div>
        <div style="font-size: 2rem; font-weight: 700;">
          <span style="color: var(--jade-glow);">新</span>
          <span style="color: var(--text-muted);">→</span>
          <span style="color: var(--gold-glow);">续</span>
          <span style="color: var(--text-muted);">→</span>
          <span style="color: var(--vermilion-glow);">用</span>
          <span style="color: var(--text-muted);">→</span>
          <span style="color: var(--jade-glow);">档</span>
        </div>
        <div style="color: var(--text-muted); font-size: 0.9rem; margin-top: 0.5rem;">
          new → continue → apply → archive
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Compatibility Section -->
  <section id="tools">
    <div class="section-label">工具兼容</div>
    <h2 class="section-title">支持 22+ AI 编码工具</h2>
    <p class="section-desc">
      不同工具的命令语法略有差异，功能完全相同。运行 <code style="color: var(--gold-glow); background: rgba(243,156,18,0.1); padding: 0.15rem 0.4rem; border-radius: 4px; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">openspec init</code> 自动配置。
    </p>

    <div class="workflow-container">
      <div style="padding: 2rem;">
        <h3 style="font-size: 1.1rem; margin-bottom: 1.5rem; color: var(--gold-glow);">命令语法对照</h3>
        <table class="ref-table">
          <thead>
            <tr>
              <th>工具</th>
              <th>语法示例</th>
              <th>说明</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Claude Code</td>
              <td>/opsx:new</td>
              <td>冒号分隔</td>
            </tr>
            <tr>
              <td>Cursor / Windsurf</td>
              <td>/opsx-new</td>
              <td>连字符分隔</td>
            </tr>
            <tr>
              <td>GitHub Copilot</td>
              <td>/opsx-new</td>
              <td>仅 IDE 扩展支持</td>
            </tr>
            <tr>
              <td>Trae</td>
              <td>/openspec-new-change</td>
              <td>完整名称格式</td>
            </tr>
            <tr>
              <td>Gemini CLI</td>
              <td>/opsx:new</td>
              <td>冒号分隔</td>
            </tr>
          </tbody>
        </table>

        <h3 style="font-size: 1.1rem; margin: 2rem 0 1rem; color: var(--jade-glow);">完整支持列表</h3>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Claude Code</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Cursor</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Windsurf</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">GitHub Copilot</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Gemini CLI</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Codex</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Amazon Q</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Trae</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Cline</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">RooCode</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Continue</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Auggie</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Qwen Code</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Kilo Code</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">OpenCode</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Qoder</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Factory Droid</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">CoStrict</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Crush</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">iFlow</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">CodeBuddy</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; padding: 0.35rem 0.75rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 100px; color: var(--jade-glow);">Antigravity</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-mantra">
      <span>新</span> → <span>续</span> → <span>用</span> → <span>档</span>
    </div>
    <p class="footer-text">
      OpenSpec 工作流指南 · 用四个字掌握规格驱动开发 · 支持 22+ AI 编码工具
    </p>
  </footer>

  <script>
    // Workflow tabs
    function showWorkflow(mode) {
      document.querySelectorAll('.workflow-tab').forEach(tab => tab.classList.remove('active'));
      document.querySelectorAll('.workflow-panel').forEach(panel => panel.classList.remove('active'));

      event.target.classList.add('active');
      document.getElementById('workflow-' + mode).classList.add('active');
    }

    // Smooth scroll for nav links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Intersection Observer for animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, observerOptions);

    document.querySelectorAll('.command-card, .scenario-box, .quick-ref').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });
  </script>
</body>
</html>
